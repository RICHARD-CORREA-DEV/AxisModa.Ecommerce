@model IEnumerable<AxisModa.Ecommerce.Web.Models.ProdutoVitrineViewModel>

@{
    ViewData["Title"] = "Vitrine de Moda";
}

@functions {
    private static string ResolverImagemProduto(string imagemUrl)
    {
        if (string.IsNullOrWhiteSpace(imagemUrl))
        {
            return "https://images.unsplash.com/photo-1523381210434-271e8be1f52b?auto=format&fit=crop&w=1200&q=80";
        }

        if (imagemUrl.Contains("photo-1596755094514", StringComparison.OrdinalIgnoreCase))
        {
            return "https://images.unsplash.com/photo-1596755094514-f87e34085b2c?auto=format&fit=crop&w=1200&q=80";
        }

        if (imagemUrl.Contains("photo-1595777457583", StringComparison.OrdinalIgnoreCase))
        {
            return "https://images.unsplash.com/photo-1595777457583-95e059d581b8?auto=format&fit=crop&w=1200&q=80";
        }

        if (imagemUrl.Contains("photo-1519457431-44ccd64a579b", StringComparison.OrdinalIgnoreCase))
        {
            return "https://images.unsplash.com/photo-1519457431-44ccd64a579b?auto=format&fit=crop&w=1200&q=80";
        }

        if (imagemUrl.Contains("photo-1515886657613", StringComparison.OrdinalIgnoreCase))
        {
            return "https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?auto=format&fit=crop&w=1200&q=80";
        }

        return imagemUrl;
    }
}

<section class="axis-hero">
    <div class="container py-5">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <p class="axis-kicker mb-3">Nova temporada AxisModa</p>
                <h1 class="axis-hero-title mb-3">Estilo autoral para quem compra com personalidade</h1>
                <p class="axis-hero-subtitle mb-4">Pecas selecionadas para elevar seu visual em qualquer ocasiao, com qualidade premium e entrega rapida.</p>
                <div class="d-flex flex-wrap gap-3">
                    <a href="#colecao" class="btn axis-btn-primary">Explorar colecao</a>
                    <a href="#diferenciais" class="btn axis-btn-outline">Conhecer beneficios</a>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="axis-hero-card shadow-sm">
                    <span class="axis-tag">Drop da Semana</span>
                    <h5 class="mt-3 mb-2">Curadoria urbana premium</h5>
                    <p class="mb-0 text-secondary">Combos de lancamento com condicoes especiais para compras online.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-4" id="diferenciais">
    <div class="container">
        <div class="row g-3">
            <div class="col-12 col-md-4">
                <div class="axis-feature shadow-sm h-100">
                    <i class="bi bi-truck"></i>
                    <div>
                        <h6>Frete gratis</h6>
                        <p>Nas compras acima de R$ 299 para todo o Brasil.</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-4">
                <div class="axis-feature shadow-sm h-100">
                    <i class="bi bi-credit-card-2-front"></i>
                    <div>
                        <h6>Parcelamento em 10x</h6>
                        <p>Pague com cartao em ate 10x sem juros.</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-4">
                <div class="axis-feature shadow-sm h-100">
                    <i class="bi bi-shield-check"></i>
                    <div>
                        <h6>Compra segura</h6>
                        <p>Transacoes protegidas com criptografia completa.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5" id="colecao">
    <div class="container">
        <div class="d-flex flex-wrap justify-content-between align-items-end gap-2 mb-4" id="novidades">
            <div>
                <p class="axis-kicker mb-1">Vitrine em destaque</p>
                <h2 class="axis-section-title mb-0">Novidades da colecao</h2>
            </div>
            <a href="#" class="axis-link">Ver tudo <i class="bi bi-arrow-right-short"></i></a>
        </div>

        <ul class="nav nav-pills justify-content-center mb-4 axis-product-tabs" id="productTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button type="button" class="nav-link active axis-filter-pill" data-filter="todos">Todos</button>
            </li>
            <li class="nav-item" role="presentation">
                <button type="button" class="nav-link axis-filter-pill" data-filter="Masculino">Masculino</button>
            </li>
            <li class="nav-item" role="presentation">
                <button type="button" class="nav-link axis-filter-pill" data-filter="Feminino">Feminino</button>
            </li>
            <li class="nav-item" role="presentation">
                <button type="button" class="nav-link axis-filter-pill" data-filter="Infantil">Infantil</button>
            </li>
        </ul>

        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4" id="productGrid">
            @if (Model != null && Model.Any())
            {
                @foreach (var produto in Model)
                {
                    var imagemProduto = ResolverImagemProduto(produto.ImagemUrl);

                    <div class="col product-item" data-category="@produto.Categoria">
                        <div class="card axis-product-card h-100 shadow-sm border-0">
                            <img src="@imagemProduto" class="card-img-top p-2 rounded-4" alt="@produto.Nome" loading="lazy" style="height: 280px; object-fit: cover; background-color: #f4f2f0;">

                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title mb-1">@produto.Nome</h5>
                                <p class="card-text text-secondary small mb-3">@produto.Descricao</p>

                                <div class="mt-auto d-flex justify-content-between align-items-center">
                                    <span class="fs-5 fw-bold">@produto.Preco.ToString("C")</span>
                                    <a href="#" class="btn axis-btn-detail btn-sm px-3 rounded-pill">Ver Detalhes</a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                @for (int i = 1; i <= 8; i++)
                {
                    <div class="col">
                        <div class="card axis-product-card h-100 shadow-sm border-0 placeholder-glow">
                            <div class="axis-placeholder-image rounded-4">
                                <i class="bi bi-image text-muted fs-1"></i>
                            </div>
                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title mb-1">Produto Esboco #@i</h5>
                                <p class="card-text text-secondary small mb-3">Descricao demonstrativa para validar responsividade, hierarquia visual e espacos comerciais da vitrine.</p>
                                <div class="mt-auto d-flex justify-content-between align-items-center">
                                    <span class="fs-5 fw-bold">R$ 99,90</span>
                                    <button class="btn axis-btn-detail btn-sm px-3 rounded-pill disabled">Ver Detalhes</button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</section>

@section Scripts {
    <script>
        (function () {
            const tabs = document.querySelectorAll("#productTabs .axis-filter-pill");
            const items = document.querySelectorAll("#productGrid .product-item");

            if (!tabs.length || !items.length) {
                return;
            }

            tabs.forEach((tab) => {
                tab.addEventListener("click", () => {
                    const filter = tab.dataset.filter;

                    tabs.forEach((btn) => btn.classList.remove("active"));
                    tab.classList.add("active");

                    items.forEach((item) => {
                        const category = item.dataset.category;
                        const show = filter === "todos" || category === filter;

                        item.classList.toggle("d-none", !show);
                    });
                });
            });
        })();
    </script>
}
