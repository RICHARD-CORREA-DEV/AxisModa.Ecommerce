@model IEnumerable<AxisModa.Ecommerce.Web.Models.ProdutoVitrineViewModel>

@{
    ViewData["Title"] = "Vitrine de Moda";
}

<div class="container my-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-dark">AxisModa</h1>
        <p class="lead text-muted">Confira os lançamentos exclusivos da nossa colecao</p>
    </div>

    <div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
        @if (Model != null && Model.Any())
        {
            @foreach (var produto in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0 transition-card">
                        <img src="@produto.ImagemUrl" class="card-img-top p-2 rounded" alt="@produto.Nome" style="height: 260px; object-fit: cover; background-color: #f8f9fa;">

                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title fw-bold text-dark mb-1">@produto.Nome</h5>
                            <p class="card-text text-muted small text-truncate mb-3">@produto.Descricao</p>

                            <div class="mt-auto d-flex justify-content-between align-items-center">
                                <span class="fs-5 fw-bold text-success">@produto.Preco.ToString("C")</span>
                                <a href="#" class="btn btn-dark btn-sm px-3 rounded-pill">Ver Detalhes</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            @for (int i = 1; i <= 4; i++)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0 placeholder-glow">
                        <div class="bg-light rounded" style="height: 260px; display: flex; align-items: center; justify-content: center;">
                            <i class="bi bi-image text-muted fs-1"></i>
                        </div>
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title fw-bold text-dark mb-1">Produto Esboco #@i</h5>
                            <p class="card-text text-muted small mb-3">Descricao demonstrativa do produto para validacao de layout Bootstrap 5.</p>
                            <div class="mt-auto d-flex justify-content-between align-items-center">
                                <span class="fs-5 fw-bold text-success">R$ 99,90</span>
                                <button class="btn btn-secondary btn-sm px-3 rounded-pill disabled">Aguardando Dados</button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>
