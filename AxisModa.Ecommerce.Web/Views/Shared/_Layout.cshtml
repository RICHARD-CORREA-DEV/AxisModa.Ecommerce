<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - AxisModa</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/AxisModa.Ecommerce.Web.styles.css" asp-append-version="true"/>
</head>
<body class="axis-body">
<header>
    <nav class="navbar navbar-expand-lg fixed-top axis-navbar">
        <div class="container py-2">
            <a class="navbar-brand axis-brand" asp-area="" asp-controller="Home" asp-action="Index">
                <span class="axis-brand-mark">A</span>
                AxisModa
            </a>
            <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarPrincipal" aria-controls="navbarPrincipal" aria-expanded="false" aria-label="Alternar navegacao">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarPrincipal">
                <ul class="navbar-nav mx-auto mb-3 mb-lg-0 gap-lg-2">
                    <li class="nav-item"><a class="nav-link axis-nav-link" href="#novidades">Novidades</a></li>
                    <li class="nav-item"><a class="nav-link axis-nav-link" href="#colecao">Colecao</a></li>
                    <li class="nav-item"><a class="nav-link axis-nav-link" href="#diferenciais">Beneficios</a></li>
                    <li class="nav-item"><a class="nav-link axis-nav-link" href="#contato">Contato</a></li>
                </ul>

                <div class="d-flex align-items-center gap-2">
                    <form class="d-none d-md-flex axis-search" role="search">
                        <i class="bi bi-search"></i>
                        <input class="form-control" type="search" placeholder="Buscar produto" aria-label="Buscar produto">
                    </form>
                    <button type="button" class="btn axis-cart-btn" aria-label="Abrir carrinho">
                        <i class="bi bi-bag"></i>
                        <span class="axis-cart-count">3</span>
                    </button>
                </div>
            </div>
        </div>
    </nav>
</header>

<main role="main" class="axis-main">
    @RenderBody()
</main>

<footer class="axis-footer" id="contato">
    <div class="container py-5">
        <div class="row g-4">
            <div class="col-12 col-md-6 col-lg-3">
                <h6 class="axis-footer-title">Sobre a Marca</h6>
                <p class="axis-footer-text">A AxisModa combina design premium, conforto e curadoria autoral para uma experiencia de compra elegante e objetiva.</p>
            </div>
            <div class="col-6 col-lg-3">
                <h6 class="axis-footer-title">Links Uteis</h6>
                <ul class="list-unstyled axis-footer-links">
                    <li><a href="#colecao">Produtos</a></li>
                    <li><a href="#diferenciais">Entrega</a></li>
                    <li><a href="#">Trocas e Devolucoes</a></li>
                    <li><a href="#">Politica de Privacidade</a></li>
                </ul>
            </div>
            <div class="col-6 col-lg-3">
                <h6 class="axis-footer-title">Redes Sociais</h6>
                <ul class="list-unstyled axis-footer-links">
                    <li><a href="#"><i class="bi bi-instagram"></i> Instagram</a></li>
                    <li><a href="#"><i class="bi bi-facebook"></i> Facebook</a></li>
                    <li><a href="#"><i class="bi bi-youtube"></i> YouTube</a></li>
                    <li><a href="#"><i class="bi bi-tiktok"></i> TikTok</a></li>
                </ul>
            </div>
            <div class="col-12 col-lg-3">
                <h6 class="axis-footer-title">Atendimento</h6>
                <p class="axis-footer-text mb-1">Seg a Sex, 09h as 18h</p>
                <p class="axis-footer-text mb-0">contato@axismoda.com</p>
            </div>
        </div>

        <div class="axis-footer-bottom mt-4 pt-3">
            <small>© @DateTime.UtcNow.Year AxisModa. Todos os direitos reservados.</small>
        </div>
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
